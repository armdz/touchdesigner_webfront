.color-palette-control {
  display: flex;
  flex-direction: column;
  padding: 8px 12px;
  height: 100%;
  box-sizing: border-box;
}

.color-palette-control .control__header {
  margin-bottom: 8px;
  flex-shrink: 0;
}

.color-palette-control__body {
  flex: 1;
  display: flex;
  gap: 6px;
  align-items: center;
  justify-content: flex-start;
  flex-wrap: wrap;
}

.color-palette-control__btn {
  width: 32px;
  height: 32px;
  border: 2px solid var(--border);
  border-radius: 4px;
  cursor: pointer;
  transition: all .15s;
  flex-shrink: 0;
}

.color-palette-control__btn:hover {
  border-color: var(--text);
  transform: scale(1.1);
}

.color-palette-control__btn:active {
  transform: scale(0.95);
}
