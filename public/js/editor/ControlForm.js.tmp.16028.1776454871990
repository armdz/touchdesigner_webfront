import { getTypes, getTypeLabel, getSchema } from '../components/registry.js';

/**
 * ControlForm — renders a form to configure and add a new control.
 *
 * Usage:
 *   const form = new ControlForm(containerEl);
 *   form.onAdd = (config) => { ... };
 */
export class ControlForm {
  constructor(container) {
    this._container = container;
    /** @type {((config: object) => void)|null} */
    this.onAdd = null;
    this._build();
  }

  _build() {
    this._container.innerHTML = '';

    const wrap = document.createElement('div');
    wrap.className = 'form';

    // ── Type selector ──────────────────────────────────────
    const typeRow = document.createElement('div');
    typeRow.className = 'form__row';
    typeRow.innerHTML = `
      <label class="form__label">Type</label>
      <select class="form__select" id="ctrlType">
        ${getTypes().map(t => `<option value="${t}">${getTypeLabel(t)}</option>`).join('')}
      </select>
    `;
    wrap.appendChild(typeRow);

    // ── Dynamic fields ─────────────────────────────────────
    this._fieldsEl = document.createElement('div');
    this._fieldsEl.className = 'form__fields';
    wrap.appendChild(this._fieldsEl);

    // ── Submit ─────────────────────────────────────────────
    const btn = document.createElement('button');
    btn.className = 'btn btn--primary btn--full';
    btn.textContent = '+ Add Control';
    btn.addEventListener('click', () => this._submit());
    wrap.appendChild(btn);

    this._container.appendChild(wrap);

    this._typeSelect = wrap.querySelector('#ctrlType');
    this._typeSelect.addEventListener('change', () => this._renderFields());
    this._renderFields();
  }

  _renderFields() {
    const schema = getSchema(this._typeSelect.value);
    this._fieldsEl.innerHTML = '';

    schema.forEach(field => {
      const row = document.createElement('div');
      row.className = 'form__row';

      const label = document.createElement('label');
      label.className = 'form__label';
      label.textContent = `${field.label}${field.required ? ' *' : ''}`;
      row.appendChild(label);

      let inputEl;
      if (field.inputType === 'select') {
        inputEl = document.createElement('select');
        inputEl.className = 'form__input';
        inputEl.name = field.key;
        inputEl.required = field.required || false;
        field.options?.forEach(opt => {
          const option = document.createElement('option');
          option.value = opt;
          option.textContent = opt;
          inputEl.appendChild(option);
        });
        if (field.default) inputEl.value = field.default;
      } else if (field.inputType === 'colorArray') {
        inputEl = this._createColorArrayInput(field);
      } else {
        inputEl = document.createElement('input');
        inputEl.className = 'form__input';
        inputEl.type = field.inputType;
        inputEl.name = field.key;
        inputEl.placeholder = field.placeholder ?? '';
        inputEl.required = field.required || false;
        if (field.default) {
          inputEl.value = Array.isArray(field.default) ? field.default.join(',') : field.default;
        }
      }

      row.appendChild(inputEl);
      this._fieldsEl.appendChild(row);
    });
  }

  _createColorArrayInput(field) {
    const container = document.createElement('div');
    container.className = 'color-array-input';
    container.name = field.key;

    const colors = Array.isArray(field.default) ? [...field.default] : ['#FF0000'];
    const hiddenInput = document.createElement('input');
    hiddenInput.type = 'hidden';
    hiddenInput.name = field.key;
    hiddenInput.value = JSON.stringify(colors);
    container.appendChild(hiddenInput);

    const colorsList = document.createElement('div');
    colorsList.className = 'color-array-input__colors';

    const renderColors = () => {
      colorsList.innerHTML = colors.map((color, idx) => `
        <div class="color-array-input__item">
          <input type="color" value="${color}" class="color-array-input__picker"
                 data-idx="${idx}" />
          <button type="button" class="color-array-input__remove" data-idx="${idx}">×</button>
        </div>
      `).join('');

      colorsList.querySelectorAll('.color-array-input__picker').forEach(picker => {
        picker.addEventListener('input', (e) => {
          colors[parseInt(e.target.dataset.idx)] = e.target.value;
          hiddenInput.value = JSON.stringify(colors);
        });
      });

      colorsList.querySelectorAll('.color-array-input__remove').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          colors.splice(parseInt(btn.dataset.idx), 1);
          if (colors.length === 0) colors.push('#FF0000');
          hiddenInput.value = JSON.stringify(colors);
          renderColors();
        });
      });
    };

    renderColors();
    container.appendChild(colorsList);

    const addBtn = document.createElement('button');
    addBtn.type = 'button';
    addBtn.className = 'btn btn--small';
    addBtn.textContent = '+ Agregar Color';
    addBtn.addEventListener('click', (e) => {
      e.preventDefault();
      colors.push('#FF0000');
      hiddenInput.value = JSON.stringify(colors);
      renderColors();
    });
    container.appendChild(addBtn);

    return container;
  }

  _submit() {
    const type   = this._typeSelect.value;
    const schema = getSchema(type);
    const config = { type };
    let valid = true;

    for (const field of schema) {
      let input = this._fieldsEl.querySelector(`[name="${field.key}"]`);
      if (!input) continue;

      let raw = input.value?.trim() ?? '';

      if (field.required && !raw) {
        input.classList.add('form__input--error');
        valid = false;
        continue;
      }
      input.classList?.remove?.('form__input--error');

      if (field.inputType === 'number') {
        config[field.key] = parseFloat(raw !== '' ? raw : field.default ?? 0);
      } else if (field.inputType === 'select') {
        config[field.key] = raw === 'true' ? true : raw === 'false' ? false : raw;
      } else if (field.inputType === 'colorArray') {
        try {
          config[field.key] = JSON.parse(raw);
        } catch {
          config[field.key] = field.default ?? ['#FF0000'];
        }
      } else {
        config[field.key] = raw || (field.key === 'label' ? config.id : '');
      }
    }

    if (!valid) return;

    // Default label to id if left blank
    if (!config.label) config.label = config.id;

    this.onAdd?.(config);
    this._renderFields(); // reset
  }
}
